param set-default CA_ROTOR0_KM  -0.001129
param set-default CA_ROTOR0_AX 0  # Rotor 0 thrust axis X component (0=no forward thrust)
param set-default CA_ROTOR0_AY 0  # Rotor 0 thrust axis Y component (0=no lateral thrust)
param set-default CA_ROTOR0_AZ -1  # Rotor 0 thrust axis Z component (-1=upward thrust)

