# === COMPLETE VTOL SAFETY BYPASSES ===\n# These parameters ensure ActuatorArmed module allows arming for Heligyro\n# All are reversible and only affect SITL testing\nparam set-default COM_ARM_VTOL_STAB 0   # Disable VTOL stability check\nparam set-default COM_ARM_ESCS 0        # Disable ESC checks (no ESCs in SITL)\nparam set-default COM_ARM_IMBAL 0       # Disable motor imbalance check\nparam set-default COM_ARM_MOT_PRE 0     # Disable motor prearm check\nparam set-default COM_ARM_SW_BTN 1      # Enable software arming (for SITL)\nparam set-default COM_PREARM_MODE 0     # Disable prearm mode\nparam set-default COM_ARM_AUTH 0       # Disable arming authorization\nparam set-default COM_ARM_EKF_POS 0     # Disable EKF position check\nparam set-default COM_ARM_EKF_VEL 0     # Disable EKF velocity check\nparam set-default COM_ARM_EKF_HGT 0     # Disable EKF height check\nparam set-default COM_ARM_EKF_YAW 0     # Disable EKF yaw check\n# === END VTOL SAFETY BYPASSES ===
# Critical arming timing fixes\nparam set-default COM_ARM_MISSION_START 1  # Auto-arm when mission starts\nparam set-default COM_ARM_DELAY 0.1        # Reduce arming delay to 0.1s\nparam set-default COM_ARM_AUTH_ID 0       # Disable arming authorization ID
