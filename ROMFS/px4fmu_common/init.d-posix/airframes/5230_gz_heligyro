param set-default FD_FAIL_R 45.0  # Increased for Heligyro's unique dynamics
param set-default FD_FAIL_P 45.0  # Increased for Heligyro's unique dynamics
param set-default FD_FAIL_R_TTRI 1.0  # Longer time to trigger (seconds) for stable flight
param set-default FD_FAIL_P_TTRI 1.0  # Longer time to trigger (seconds) for stable flight

param set-default CA_AIRFRAME 196  # HELIGYRO_VTOL - required for ActuatorEffectivenessHeligyroVTOL

# Logging configuration
